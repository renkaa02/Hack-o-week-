import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

data = pd.read_csv("path_to_your_kaggle_dataset.csv")

print("Original Data:")
print(data.head())

numeric_cols = data.select_dtypes(include=np.number).columns
data[numeric_cols] = data[numeric_cols].fillna(data[numeric_cols].mean())

for col in data.select_dtypes(include='object').columns:
    data[col].fillna(data[col].mode()[0], inplace=True)

Q1 = data[numeric_cols].quantile(0.25)
Q3 = data[numeric_cols].quantile(0.75)
IQR = Q3 - Q1

clean_data = data[~((data[numeric_cols] < (Q1 - 1.5 * IQR)) | 
                    (data[numeric_cols] > (Q3 + 1.5 * IQR))).any(axis=1)]

plt.figure(figsize=(12, 6))

plt.subplot(1, 2, 1)
plt.boxplot(data[numeric_cols].values)
plt.title("Before Outlier Removal")

plt.subplot(1, 2, 2)
plt.boxplot(clean_data[numeric_cols].values)
plt.title("After Outlier Removal")

plt.show()

clean_data.to_csv("cleaned_sensor_data.csv", index=False)

print("\nCleaned Data:")
print(clean_data.head())
print("\n✅ Data cleaning completed successfully! Saved as 'cleaned_sensor_data.csv'")
